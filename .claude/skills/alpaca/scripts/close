#!/usr/bin/env bash
# Close a position at market (or a percentage of it).
#   close AAPL              (closes the whole position)
#   close AAPL 50           (closes 50% of the position)
source "$(dirname "${BASH_SOURCE[0]}")/_common.sh"

if [[ $# -lt 1 || $# -gt 2 ]]; then
  echo "usage: close SYMBOL [PERCENT]" >&2
  exit 2
fi

sym="$1"
path="/v2/positions/$sym"
if [[ $# -eq 2 ]]; then
  pct="$2"
  path="$path?percentage=$pct"
fi
ac_delete "$path"
