# TicketRadar — Environment Variables
# Copy this file to .env and fill in your values.

# ── Telegram Bot ──
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── SeatGeek API ──
SEATGEEK_CLIENT_ID=your_seatgeek_client_id
SEATGEEK_CLIENT_SECRET=your_seatgeek_client_secret

# ── Ticketmaster API ──
TICKETMASTER_API_KEY=your_ticketmaster_api_key

# ── Anthropic (AI features) ──
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Last.fm (artist popularity enrichment) ──
LASTFM_API_KEY=your_lastfm_api_key

# ── Google Sheet (optional — CSV export URL) ──
SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv

# ── Stripe (payments) ──
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_pro_plan_price_id

# ── Supabase (for Stripe webhook → plan update) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── CORS ──
ALLOWED_ORIGIN=https://fredericnjoh-lab.github.io

# ── Backend URL (used for Telegram webhook setup) ──
BACKEND_URL=https://ticketradar-backend.onrender.com

# ── Default margin threshold % ──
DEFAULT_SEUIL=30

# ═══════════════════════════════════════════
# POLY//ARBI — Polymarket Arbitrage Terminal
# ═══════════════════════════════════════════

# ── Server ──
POLYARBI_PORT=3001
POLYARBI_ALLOWED_ORIGIN=https://fredericnjoh-lab.github.io
POLYARBI_BACKEND_URL=https://polyarbi.onrender.com

# ── Polygonscan (wallet tracking) ──
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# ── Polymarket CLOB API (for order execution) ──
# Get your keys at: https://polymarket.com/settings/api
POLYMARKET_API_KEY=your_polymarket_api_key
POLYMARKET_API_SECRET=your_polymarket_api_secret
POLYMARKET_API_PASSPHRASE=your_polymarket_passphrase

# ── Polygon Wallet (for signing trades) ──
# WARNING: This is the private key of the wallet that will execute trades!
# Never commit this. Use Render env vars.
POLYARBI_PRIVATE_KEY=your_polygon_wallet_private_key

# ── Copytrade Safety Limits ──
COPYTRADE_MAX_PER_TRADE=50
COPYTRADE_MAX_DAILY=500
COPYTRADE_MAX_POSITIONS=10
COPYTRADE_MIN_EDGE=2.0
COPYTRADE_AUTO=false
COPYTRADE_COOLDOWN=60000

# ═══════════════════════════════════════════
# TRADING BOT — Claude Code cloud routines
# ═══════════════════════════════════════════
# Put these into each cloud routine's environment in the Claude Code web UI.
# Do NOT commit real values. Start on paper — only flip ALPACA_PAPER=false
# after you've watched it on paper for at least a week.

# ── Alpaca ──
# Get keys at https://app.alpaca.markets/paper/dashboard/overview
ALPACA_KEY_ID=your_alpaca_key_id
ALPACA_SECRET_KEY=your_alpaca_secret_key
# Paper by default. Set to false to route to the live account.
ALPACA_PAPER=true
# Hard dollar cap per single order — defence-in-depth vs. strategy rules.
ALPACA_MAX_ORDER_USD=2500

