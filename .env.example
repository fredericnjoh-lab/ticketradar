# TicketRadar — Environment Variables
# Copy this file to .env and fill in your values.

# ── Telegram Bot ──
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── SeatGeek API ──
SEATGEEK_CLIENT_ID=your_seatgeek_client_id
SEATGEEK_CLIENT_SECRET=your_seatgeek_client_secret

# ── Ticketmaster API ──
TICKETMASTER_API_KEY=your_ticketmaster_api_key

# ── Anthropic (AI features) ──
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Google Sheet (optional — CSV export URL) ──
SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv

# ── CORS ──
ALLOWED_ORIGIN=https://fredericnjoh-lab.github.io

# ── Backend URL (used for Telegram webhook setup) ──
BACKEND_URL=https://ticketradar-backend.onrender.com

# ── Default margin threshold % ──
DEFAULT_SEUIL=30
